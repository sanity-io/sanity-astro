---
import Layout from '../../layout.astro'
import {getLiveEntry} from 'astro:content'

const id = Astro.params.id

if (!id) {
  Astro.response.status = 404
  throw new Error('Movie ID is required.')
}

const {entry, error} = await getLiveEntry('movie', id)
const entryData = (entry?.data ?? {}) as {title?: string; releaseDate?: string}
const movie = entry
  ? {
      _id: entry.id,
      title: entryData.title ?? 'Untitled movie',
      releaseDate: typeof entryData.releaseDate === 'string' ? entryData.releaseDate : undefined,
    }
  : null

if (error || !movie) {
  Astro.response.status = 404
}
---

<Layout title={movie ? movie.title : 'Movie Not Found'}>
  {
    movie ? (
      <>
        <p>
          <a href="/">Back to all movies</a>
        </p>
        <h2>{movie.title}</h2>
        {movie.releaseDate ? (
          <p>Release date: {new Date(movie.releaseDate).toLocaleDateString()}</p>
        ) : null}
        <p>
          Movie ID: <code>{movie._id}</code>
        </p>
      </>
    ) : (
      <>
        <h1>Movie Not Found</h1>
        <p>
          <a href="/">Back to all movies</a>
        </p>
      </>
    )
  }
</Layout>
