{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "pipeline": {
    "clean": {
      "cache": false
    },
    "build": {
      "env": [
        "PUBLIC_SANITY_PROJECT_ID",
        "PUBLIC_SANITY_DATASET",
        "SANITY_API_READ_TOKEN"
      ],
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "build/**",
        "public/**",
        ".vercel/output/**"
      ]
    },
    "lint": {},
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
